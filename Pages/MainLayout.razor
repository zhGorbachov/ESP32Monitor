@inherits LayoutComponentBase

<div class="app-shell">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-icon">&#128161;</span>
            <span class="brand-text">ESP32 Monitor</span>
        </div>
        <ul class="nav-links">
            <li>
                <NavLink href="/" Match="NavLinkMatch.All">
                    <span class="nav-icon">&#128202;</span> Dashboard
                </NavLink>
            </li>
            <li>
                <NavLink href="/effects">
                    <span class="nav-icon">&#127752;</span> Effects
                </NavLink>
            </li>
        </ul>
    </nav>

    <main class="content-area">
        <div class="topbar">
            <h1 class="page-title">@TitleContent</h1>
        </div>
        <div class="page-body">
            @Body
        </div>
    </main>
</div>

@code {
    [CascadingParameter] private string? TitleContent { get; set; }
}
